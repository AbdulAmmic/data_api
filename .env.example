# -------------------------
# FLASK
# -------------------------
FLASK_ENV=development
APP_SECRET_KEY=your_app_secret_here
JWT_SECRET_KEY=your_jwt_secret_here
JWT_EXPIRES_HOURS=72
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# -------------------------
# PAYSTACK
# -------------------------
GSECRET_KEY=your_secret_key_here
PAYSTACK_PUBLIC_KEY=your_public_key_here
PAYSTACK_CALLBACK_URL=https://your-frontend.com/paystack/callback
paystack_base_url=https://api.paystack.co

# -------------------------
# MONNIFY
# -------------------------
MONNIFY_SECRET_KEY=your_monnify_secret_key
MONNIFY_API_KEY=your_monnify_api_key
MONNIFY_CONTRACT_CODE=your_contract_code

# -------------------------
# BILALSADASUB
# -------------------------
BILALSADASUB_TOKEN=your_bilalsadasub_token
BILALSADASUB_BASE_URL=https://bilalsadasub.com
BILALSADASUB_USERNAME=your_bilalsadasub_username
BILALSADASUB_PASSWORD=your_bilalsadasub_password

# Deprecated aliases
DATASTATION_TOKEN=your_bilalsadasub_token
DATASTATION_BASE_URL=https://bilalsadasub.com

# -------------------------
# GAFIAPAY
# -------------------------
GAFIAPAY_SECRET_KEY=your_gafiapay_secret_key
GAFIAPAY_API_KEY=your_gafiapay_api_key
GAFIAPAY_BASE_URL=https://api.gafiapay.com/api/v1/external

# -------------------------
# CHEETAHPAY
# -------------------------
CHEETAHPAY_PUBLIC_KEY=your_public_key
CHEETAHPAY_PRIVATE_KEY=your_private_key
CHEETAHPAY_MODE=live
